/* pages/index/index.wxss */
page {
    background-color: #f4f7f6;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

.container {
    padding: 20rpx;
    display: flex;
    flex-direction: column;
}

.header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    padding: 10rpx 10rpx 30rpx;
}

.header .title {
    font-size: 40rpx;
    font-weight: bold;
    color: #333;
}

.header .time {
    font-size: 24rpx;
    color: #888;
}

/* 新增：用户配置区域样式 */
.config-section {
    background-color: #fff;
    border-radius: 16rpx;
    padding: 20rpx 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    gap: 15rpx;
}

.config-item {
    display: flex;
    align-items: center;
    padding: 10rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
}

.config-item:last-child {
    border-bottom: none;
}

.config-label {
    font-size: 28rpx;
    color: #666;
    flex-shrink: 0;
}

.config-value {
    font-size: 30rpx;
    font-weight: bold;
    color: #4CAF50;
    margin-left: 10rpx;
    flex-grow: 1;
    text-align: right;
}

.config-input {
    font-size: 30rpx;
    color: #333;
    padding: 0 10rpx;
    flex-grow: 1;
    text-align: right;
}

.data-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    margin-bottom: 30rpx;
}

.data-card {
    width: 31%; /* Changed to fit 3 columns */
    background-color: #fff;
    border-radius: 16rpx;
    padding: 24rpx 10rpx;
    box-sizing: border-box;
    margin-bottom: 20rpx;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
}

.data-card .label {
    font-size: 24rpx;
    color: #666;
    margin-bottom: 10rpx;
}

.data-card .value {
    font-size: 36rpx;
    font-weight: bold;
}

.unit {
    font-size: 20rpx;
    font-weight: normal;
    color: #999;
}

/* 区分不同数据的颜色 */
.temp { color: #FF5722; }
.hum { color: #03A9F4; }
.light { color: #FFC107; }
.soil { color: #795548; }
.soilTemp { color: #E64A19; }
.soilEC { color: #8E24AA; }
.soilPH { color: #00897B; }

.chart-container, .ai-container {
    background-color: #fff;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 20rpx;
    display: block;
}

.echarts-box {
    width: 100%;
    height: 500rpx;
    background-color: #fff;
    border-radius: 8rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}

ec-canvas {
    width: 100%;
    height: 100%;
}

.placeholder-text {
    color: #bbb;
    font-size: 28rpx;
}

.ai-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
}

.ai-btn {
    margin: 0;
    font-size: 24rpx;
    background-color: #4CAF50;
    color: #fff;
    border-radius: 30rpx;
    padding: 0 30rpx;
}

.ai-content {
    background-color: #e8f5e9;
    padding: 20rpx;
    border-radius: 12rpx;
    border-left: 8rpx solid #4CAF50;
}

.ai-text {
    font-size: 28rpx;
    color: #2e7d32;
    line-height: 1.6;
}